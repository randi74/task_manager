generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id       Int    @id @default(autoincrement())
  username String
  createdAt DateTime @default(now())

  log Log[]
  // task Task[]

  @@map("users")
}

enum statusEnum {
  TODO
  PENDING
  IN_PROGRESS
  DONE
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  status      statusEnum @default(TODO)

  // user User @relation(fields: [user_id], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  log Log[]

  @@map("tasks")
}

enum actionEnum {
  CREATE
  UPDATE
  DELETE
}

model Log {
  id       Int        @id @default(autoincrement())
  task_id  Int?
  actor_id Int
  action   actionEnum
  from_status statusEnum?
  to_status statusEnum?

  tasks Task? @relation(fields: [task_id], references: [id], onDelete: SetNull)
  users User @relation(fields: [actor_id], references: [id])

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
