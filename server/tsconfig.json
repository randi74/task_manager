{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "target": "es2023", 
    "module": "NodeNext", 
    "lib": ["ES2022"], 
    // "rootDir": "./src", 
    "outDir": "./dist", 
    "esModuleInterop": true, 
    "types": ["node"],
    "forceConsistentCasingInFileNames": true, 
    "strict": true, 
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "ignoreDeprecations": "6.0" 
  },
  "include": ["src/**/*", "generated/**/*"],
  "ts-node": {
  "esm": true,
  "experimentalSpecifierResolution": "node"
}
}